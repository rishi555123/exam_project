<%- include('partials/header') %>
<div class="max-w-[1400px] mx-auto px-6 py-10 italic font-black">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="space-y-6">
            <div class="bg-white p-8 rounded-[3rem] shadow-xl border-t-8 border-indigo-600">
                <h3 class="mb-4 uppercase text-[10px] text-slate-400">Manual Student Entry</h3>
                <form action="/add-student-single" method="POST" class="flex flex-col gap-3">
                    <input name="roll" placeholder="Roll Number" class="p-4 border rounded-2xl bg-slate-50 outline-none" required>
                    <input name="name" placeholder="Full Name" class="p-4 border rounded-2xl bg-slate-50 outline-none" required>
                    <select name="branch" class="p-4 border rounded-2xl bg-slate-50 outline-none">
                        <% branches.forEach(b => { %> <option value="<%= b %>"><%= b %></option> <% }) %>
                    </select>
                    <input name="year" type="number" placeholder="Year (1-4)" class="p-4 border rounded-2xl bg-slate-50 outline-none" required>
                    <button class="bg-indigo-600 text-white py-4 rounded-2xl uppercase shadow-lg hover:bg-indigo-700">Save Student</button>
                </form>
            </div>
            <div class="bg-white p-8 rounded-[3rem] shadow-xl border-t-8 border-emerald-600">
                <h3 class="mb-4 uppercase text-[10px] text-slate-400">Bulk Upload (Roll,Name,Year,Branch)</h3>
                <form action="/bulk-upload" method="POST">
                    <textarea name="csv_data" rows="5" class="w-full p-4 border rounded-2xl bg-slate-50 mb-4 outline-none" placeholder="24241A0555,Rishith,2,CSE"></textarea>
                    <button class="w-full bg-slate-900 text-white py-4 rounded-2xl uppercase hover:bg-black">Process Batch</button>
                </form>
            </div>
        </div>
        <div class="bg-white rounded-[3rem] shadow-2xl border overflow-hidden h-fit">
            <table class="w-full text-left text-[10px]">
                <thead class="bg-slate-950 text-indigo-300 uppercase italic">
                    <tr><th class="p-6">Identity</th><th class="p-6">Department</th><th class="p-6 text-right pr-10">Control</th></tr>
                </thead>
                <tbody class="divide-y">
                    <% students.forEach(s => { %>
                        <tr>
                            <td class="p-6 font-black"><%= s.roll_no %><br><span class="text-[9px] text-slate-400"><%= s.name %></span></td>
                            <td class="p-6 uppercase text-indigo-600"><%= s.branch %> | Year <%= s.year %></td>
                            <td class="p-6 pr-10 text-right"><a href="/delete-student/<%= s.id %>" class="text-red-500 font-black uppercase hover:underline">Delete</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>