<%- include('partials/header') %>

<div style="max-width:1300px;margin:0 auto;padding:32px 24px;font-style:italic;font-weight:900;">

    <!-- Page title -->
    <div style="text-align:center;margin-bottom:40px;">
        <h1 style="font-size:36px;text-transform:uppercase;letter-spacing:-0.02em;color:var(--text);line-height:1;">Seating Engine</h1>
        <p style="font-size:9px;color:var(--text3);margin-top:10px;letter-spacing:0.4em;text-transform:uppercase;">Official Automated Examination Control</p>
    </div>

    <form id="allocationForm" action="/generate" method="POST" onsubmit="return validateForm(event)">

        <!-- Row 1: Date + Session + Jumble -->
        <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:16px;margin-bottom:16px;">

            <!-- Date -->
            <div class="t-card" style="padding:24px;">
                <p class="t-label" style="margin-bottom:10px;">Exam Date</p>
                <input type="date" name="exam_date" value="<%= selDate %>"
                       onchange="location.href='/?date='+this.value+'&session=<%= selSession %>'"
                       class="t-input" style="cursor:pointer;">
            </div>

            <!-- Session -->
            <div class="t-card" style="padding:24px;">
                <p class="t-label" style="margin-bottom:10px;">Session</p>
                <div style="display:flex;gap:8px;">
                    <button type="button"
                        onclick="location.href='/?date=<%= selDate %>&session=FN'"
                        style="flex:1;padding:12px;border-radius:12px;font-size:10px;font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;transition:all 0.2s;border:1px solid;
                        <%= selSession=='FN' ? 'background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 4px 16px var(--accent-glow);' : 'background:var(--card2);color:var(--text2);border-color:var(--border2);' %>">
                        ☀️ Forenoon
                    </button>
                    <button type="button"
                        onclick="location.href='/?date=<%= selDate %>&session=AN'"
                        style="flex:1;padding:12px;border-radius:12px;font-size:10px;font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;transition:all 0.2s;border:1px solid;
                        <%= selSession=='AN' ? 'background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 4px 16px var(--accent-glow);' : 'background:var(--card2);color:var(--text2);border-color:var(--border2);' %>">
                        🌙 Afternoon
                    </button>
                    <input type="hidden" name="exam_session" value="<%= selSession %>">
                </div>
            </div>

            <!-- Jumble -->
            <div class="t-card" style="padding:24px;min-width:200px;display:flex;flex-direction:column;justify-content:space-between;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                    <p class="t-label">Jumble Mode</p>
                    <div style="width:28px;height:28px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-shield-alt" style="color:#fff;font-size:11px;"></i>
                    </div>
                </div>
                <label style="display:flex;align-items:center;gap:12px;cursor:pointer;padding:10px;background:var(--card2);border-radius:12px;border:1px solid var(--border);">
                    <input type="checkbox" name="jumble_mode" value="true" id="jumbleCheck" style="display:none;">
                    <div id="jumbleToggle" onclick="toggleJumble()" style="width:44px;height:24px;border-radius:99px;background:var(--border2);position:relative;transition:background 0.25s;cursor:pointer;flex-shrink:0;">
                        <div id="jumbleThumb" style="width:18px;height:18px;background:#fff;border-radius:50%;position:absolute;top:3px;left:3px;transition:left 0.25s;"></div>
                    </div>
                    <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.15em;color:var(--text2);">Alternate Seating</span>
                </label>
            </div>
        </div>

        <!-- Row 2: Year selection -->
        <div class="t-card" style="padding:28px;margin-bottom:16px;">
            <p class="t-label" style="margin-bottom:18px;"><span style="background:var(--accent);color:#fff;padding:3px 10px;border-radius:6px;margin-right:8px;">02</span> Target Academic Year</p>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;">
                <% [1,2,3,4].forEach(y => { %>
                    <div>
                        <input type="radio" name="selected_year" value="<%= y %>" id="yr_<%= y %>" style="display:none;" onclick="showBranches(<%= y %>)">
                        <label for="yr_<%= y %>" style="display:block;padding:28px 16px;border:2px solid var(--border2);border-radius:20px;text-align:center;cursor:pointer;transition:all 0.25s;background:var(--card2);"
                               onmouseover="this.style.borderColor='var(--accent)'"
                               onmouseout="if(!document.getElementById('yr_<%= y %>').checked)this.style.borderColor='var(--border2)'">
                            <div style="font-size:24px;text-transform:uppercase;letter-spacing:-0.03em;color:var(--text);">
                                <%= y %><%= y==1?'st':y==2?'nd':y==3?'rd':'th' %>
                            </div>
                            <div style="font-size:9px;color:var(--text3);margin-top:6px;font-family:monospace;">
                                <%= stats[y] ? stats[y].total : 0 %> students
                            </div>
                        </label>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Row 3: Branch selection (hidden) -->
        <div id="branchSection" style="display:none;margin-bottom:16px;">
            <div class="t-card" style="padding:28px;">
                <p class="t-label" style="margin-bottom:18px;text-align:center;color:var(--accent);">
                    <span style="background:var(--accent);color:#fff;padding:3px 10px;border-radius:6px;margin-right:8px;">03</span> Department Selection
                </p>
                <div id="branchList" style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;"></div>
            </div>
        </div>

        <!-- Row 4: Rooms -->
        <div style="background:var(--card);border:1px solid var(--border);border-radius:24px;padding:28px;margin-bottom:16px;">
            <p class="t-label" style="margin-bottom:18px;">
                <span style="background:var(--text);color:var(--bg);padding:3px 10px;border-radius:6px;margin-right:8px;">04</span> Select Examination Halls
            </p>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:10px;margin-bottom:24px;">
                <% rooms.forEach(r => { %>
                    <div>
                        <input type="checkbox" name="selected_rooms" value="<%= r.id %>" id="rm_<%= r.id %>"
                               style="display:none;" class="roomCheck" <%= bookedIds.includes(r.id) ? 'disabled' : '' %>>
                        <label for="rm_<%= r.id %>"
                               style="display:block;padding:16px 6px;border:2px solid var(--border2);border-radius:14px;text-align:center;font-size:11px;text-transform:uppercase;transition:all 0.2s;
                               <%= bookedIds.includes(r.id) ? 'opacity:0.2;cursor:not-allowed;' : 'cursor:pointer;background:var(--card2);color:var(--text);' %>">
                            <%= r.room_number %>
                        </label>
                    </div>
                <% }) %>
            </div>

            <button type="submit" style="width:100%;background:var(--accent);color:#fff;padding:20px;border-radius:18px;border:none;font-size:11px;font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:0.3em;cursor:pointer;box-shadow:0 8px 32px var(--accent-glow);transition:all 0.2s;"
                    onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
                Generate Official Allocation Plan &nbsp; →
            </button>
        </div>
    </form>
</div>

<script>
    const allStats = <%- JSON.stringify(stats) %>;
    let jumbleOn = false;

    function toggleJumble() {
        jumbleOn = !jumbleOn;
        document.getElementById('jumbleCheck').checked = jumbleOn;
        document.getElementById('jumbleToggle').style.background = jumbleOn ? 'var(--green)' : 'var(--border2)';
        document.getElementById('jumbleThumb').style.left = jumbleOn ? '23px' : '3px';
    }

    // Room label highlight on check
    document.querySelectorAll('.roomCheck').forEach(cb => {
        cb.addEventListener('change', function() {
            const lbl = document.querySelector(`label[for="${this.id}"]`);
            if (this.checked) {
                lbl.style.background = 'var(--accent)';
                lbl.style.color = '#fff';
                lbl.style.borderColor = 'var(--accent)';
                lbl.style.transform = 'scale(1.08)';
            } else {
                lbl.style.background = 'var(--card2)';
                lbl.style.color = 'var(--text)';
                lbl.style.borderColor = 'var(--border2)';
                lbl.style.transform = 'scale(1)';
            }
        });
    });

    // Year label highlight
    document.querySelectorAll('[id^="yr_"]').forEach(rb => {
        rb.addEventListener('change', function() {
            document.querySelectorAll('[id^="yr_"]').forEach(r => {
                const l = document.querySelector(`label[for="${r.id}"]`);
                l.style.borderColor = 'var(--border2)';
                l.style.background = 'var(--card2)';
            });
            const lbl = document.querySelector(`label[for="${this.id}"]`);
            lbl.style.borderColor = 'var(--accent)';
            lbl.style.background = 'var(--accent-glow)';
        });
    });

    function showBranches(year) {
        const section = document.getElementById('branchSection');
        const list = document.getElementById('branchList');
        section.style.display = 'block';
        list.innerHTML = '';
        const brs = ['CSE','AIML','CSDS','MECH','CIVIL','ECE'];
        brs.forEach(b => {
            const count = (allStats[year] && allStats[year].branches[b]) || 0;
            list.innerHTML += `
                <div>
                    <input type="checkbox" name="selected_branches" value="${b}" id="br_${b}" style="display:none;" class="branchCheck">
                    <label for="br_${b}" style="display:block;padding:12px 22px;border:2px solid var(--border2);border-radius:14px;cursor:pointer;font-size:10px;text-transform:uppercase;color:var(--text2);background:var(--card2);transition:all 0.2s;white-space:nowrap;">
                        ${b} <span style="opacity:0.4;font-family:monospace;margin-left:6px;">${count}</span>
                    </label>
                </div>`;
        });
        document.querySelectorAll('.branchCheck').forEach(cb => {
            cb.addEventListener('change', function() {
                const lbl = document.querySelector(`label[for="${this.id}"]`);
                if (this.checked) { lbl.style.background='var(--accent)'; lbl.style.color='#fff'; lbl.style.borderColor='var(--accent)'; }
                else { lbl.style.background='var(--card2)'; lbl.style.color='var(--text2)'; lbl.style.borderColor='var(--border2)'; }
            });
        });
        section.scrollIntoView({ behavior:'smooth', block:'center' });
    }

    function validateForm(event) {
        event.preventDefault();
        const year = document.querySelector('input[name="selected_year"]:checked');
        const branches = document.querySelectorAll('input[name="selected_branches"]:checked');
        const rooms = document.querySelectorAll('input[name="selected_rooms"]:checked');
        if (!year || branches.length === 0 || rooms.length === 0) {
            Swal.fire({ icon:'info', title:'Incomplete Selection', text:'Please select Year, Branch and Halls.', confirmButtonColor:'var(--accent)', background:'var(--card)', color:'var(--text)' });
            return false;
        }
        Swal.fire({ title:'Generating Plan', text:'Allocating and optimizing...', background:'var(--card)', color:'var(--text)', allowOutsideClick:false,
            didOpen:() => { Swal.showLoading(); document.getElementById('allocationForm').submit(); }
        });
        return true;
    }
</script>
