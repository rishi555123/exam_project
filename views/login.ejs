<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GRIET EMS — Admin Login</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #020617;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: sans-serif;
        }
        .card { width: 100%; max-width: 380px; padding: 0 24px; }
        .brand { text-align: center; margin-bottom: 36px; }
        .brand h1 { color: #fff; font-size: 22px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; font-style: italic; }
        .brand p { color: #64748b; font-size: 10px; text-transform: uppercase; letter-spacing: 0.3em; margin-top: 6px; }
        .box { background: #0f172a; border: 1px solid #1e293b; border-radius: 16px; padding: 32px; }
        .error-box { background: #1c0a0a; border: 1px solid #7f1d1d; color: #fca5a5; font-size: 11px; font-weight: 700; text-transform: uppercase; border-radius: 10px; padding: 10px 14px; margin-bottom: 20px; text-align: center; }
        .field { margin-bottom: 16px; }
        label { display: block; color: #94a3b8; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 8px; }
        input[type="text"], input[type="password"] { width: 100%; background: #1e293b; border: 1px solid #334155; color: #fff; border-radius: 10px; padding: 12px 16px; font-size: 14px; font-weight: 700; outline: none; transition: border-color 0.2s; }
        input[type="text"]:focus, input[type="password"]:focus { border-color: #6366f1; }
        button[type="submit"] { width: 100%; background: #4f46e5; color: #fff; font-weight: 900; font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; padding: 14px; border: none; border-radius: 10px; cursor: pointer; margin-top: 8px; transition: background 0.2s; }
        button[type="submit"]:hover { background: #4338ca; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">
            <h1>GRIET EMS</h1>
            <p>Exam Management System</p>
        </div>
        <div class="box">
            <% if (error) { %>
                <div class="error-box"><%= error %></div>
            <% } %>
            <form action="/login" method="POST">
                <div class="field">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required autocomplete="username" placeholder="Enter username">
                </div>
                <div class="field">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="Enter password">
                </div>
                <button type="submit">Login</button>
            </form>
        </div>
    </div>
</body>
</html>