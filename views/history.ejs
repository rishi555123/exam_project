<%- include('partials/header') %>

<div style="max-width:1300px;margin:0 auto;padding:32px 24px;font-style:italic;font-weight:900;">

    <!-- Header row -->
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div>
            <h2 style="font-size:26px;text-transform:uppercase;letter-spacing:-0.02em;color:var(--text);">Allocation History</h2>
            <p style="font-size:9px;color:var(--text3);margin-top:6px;text-transform:uppercase;letter-spacing:0.3em;">View or reprint past seating charts</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
            <button onclick="confirmClearAll()" class="btn-danger">🗑️ Clear All</button>
            <button onclick="document.getElementById('swapModal').style.display='flex'" style="background:rgba(245,158,11,0.1);color:var(--amber);border:1px solid rgba(245,158,11,0.3);border-radius:12px;padding:8px 16px;font-size:9px;font-weight:900;font-style:italic;text-transform:uppercase;cursor:pointer;transition:all 0.2s;"
                onmouseover="this.style.background='var(--amber)';this.style.color='#fff'"
                onmouseout="this.style.background='rgba(245,158,11,0.1)';this.style.color='var(--amber)'">🔄 Swap Hall</button>
            <button onclick="document.getElementById('findModal').style.display='flex'" class="btn-primary">🔍 Student Finder</button>
            <form action="/history" method="GET" style="display:flex;gap:6px;margin:0;">
                <input type="date" name="searchDate" value="<%= searchDate %>" class="t-input" style="width:auto;padding:8px 12px;">
                <button type="submit" class="btn-secondary" style="padding:8px 16px;white-space:nowrap;">Filter</button>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="t-card" style="overflow:hidden;">
        <table class="t-table">
            <thead>
                <tr>
                    <th style="text-align:left;">Hall</th>
                    <th style="text-align:left;">Allocation Details</th>
                    <th style="text-align:center;">Session</th>
                    <th style="text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (records && records.length > 0) { %>
                    <% records.forEach(r => { %>
                        <tr>
                            <td style="font-weight:900;color:var(--accent);text-transform:uppercase;font-size:13px;">
                                Hall <%= r.room_number %>
                            </td>
                            <td>
                                <span style="color:var(--text);font-weight:900;text-transform:uppercase;"><%= r.branch %> · Yr <%= r.year %></span><br>
                                <span style="font-size:9px;color:var(--text3);font-family:monospace;"><%= new Date(r.exam_date).toISOString().split('T')[0] %></span>
                            </td>
                            <td style="text-align:center;">
                                <span class="t-badge"><%= r.exam_session %></span>
                            </td>
                            <td style="text-align:center;">
                                <div style="display:flex;gap:6px;justify-content:center;">
                                    <form action="/reprint-paper" method="POST" target="_blank" style="margin:0;">
                                        <input type="hidden" name="room_id" value="<%= r.room_id %>">
                                        <input type="hidden" name="date" value="<%= r.exam_date %>">
                                        <input type="hidden" name="session" value="<%= r.exam_session %>">
                                        <button type="submit" class="btn-primary" style="padding:7px 14px;font-size:9px;">Print A4</button>
                                    </form>
                                    <button onclick="confirmDelete(<%= r.id %>)" class="btn-danger" style="padding:7px 14px;">Remove</button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" style="padding:60px;text-align:center;color:var(--text3);text-transform:uppercase;letter-spacing:0.3em;">
                            No allocations recorded.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Swap Modal -->
<div id="swapModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);z-index:300;align-items:center;justify-content:center;padding:16px;">
    <div class="t-card" style="max-width:420px;width:100%;padding:32px;border:2px solid var(--amber);">
        <h3 style="font-size:18px;text-transform:uppercase;text-align:center;margin-bottom:20px;color:var(--text);">🔄 Room Swap</h3>
        <div style="display:flex;flex-direction:column;gap:12px;">
            <div class="t-card2" style="padding:16px;">
                <p class="t-label" style="margin-bottom:10px;">Step 1 · Verify Current Allocation</p>
                <input type="text" id="swapRoomNo" placeholder="Room Number" class="t-input" style="margin-bottom:8px;">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                    <input type="date" id="swapDate" class="t-input">
                    <select id="swapSession" class="t-input">
                        <option value="FN">FN (Morning)</option>
                        <option value="AN">AN (Afternoon)</option>
                    </select>
                </div>
                <button onclick="checkRoomForSwap()" class="btn-secondary" style="width:100%;margin-top:10px;">Verify</button>
            </div>
            <div id="swapActionArea" style="display:none;" class="t-card2" style="padding:16px;">
                <p id="currentAllocInfo" style="font-size:10px;color:var(--amber);text-align:center;margin-bottom:10px;text-transform:uppercase;"></p>
                <p class="t-label" style="margin-bottom:6px;">Step 2 · Select Destination Hall</p>
                <select id="availableRoomsSelect" class="t-input" style="margin-bottom:10px;"></select>
                <button onclick="confirmSmartSwap()" style="width:100%;background:var(--amber);color:#000;border:none;border-radius:12px;padding:12px;font-size:10px;font-weight:900;font-style:italic;text-transform:uppercase;cursor:pointer;">Confirm Swap</button>
            </div>
            <button onclick="document.getElementById('swapModal').style.display='none'" style="background:none;border:none;color:var(--text3);font-size:10px;font-weight:900;text-transform:uppercase;cursor:pointer;padding:6px;">Cancel</button>
        </div>
    </div>
</div>

<!-- Find Modal -->
<div id="findModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);z-index:300;align-items:center;justify-content:center;padding:16px;">
    <div class="t-card" style="max-width:400px;width:100%;padding:32px;border:2px solid var(--accent);">
        <h3 style="font-size:18px;text-transform:uppercase;text-align:center;margin-bottom:20px;color:var(--text);">🔍 Student Finder</h3>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <input type="text" id="findRoll" placeholder="Roll Number" class="t-input">
            <input type="date" id="findDate" class="t-input">
            <select id="findSession" class="t-input">
                <option value="FN">Forenoon (FN)</option>
                <option value="AN">Afternoon (AN)</option>
            </select>
            <button onclick="searchStudent()" class="btn-primary" style="width:100%;padding:14px;">Search</button>
            <button onclick="document.getElementById('findModal').style.display='none'" style="background:none;border:none;color:var(--text3);font-size:10px;font-weight:900;text-transform:uppercase;cursor:pointer;padding:6px;">Close</button>
        </div>
    </div>
</div>

<script>
let activeAllocationId = null;

function confirmClearAll() {
    Swal.fire({ title:'Clear All History?', text:'This cannot be undone.', icon:'warning', showCancelButton:true,
        confirmButtonColor:'var(--red)', cancelButtonColor:'var(--card2)', confirmButtonText:'Delete All',
        background:'var(--card)', color:'var(--text)'
    }).then(r => { if (r.isConfirmed) window.location.href='/clear-history'; });
}

function confirmDelete(id) {
    Swal.fire({ title:'Delete Record?', text:'This allocation will be permanently removed.', icon:'question', showCancelButton:true,
        confirmButtonColor:'var(--red)', cancelButtonColor:'var(--card2)', confirmButtonText:'Delete',
        background:'var(--card)', color:'var(--text)'
    }).then(r => { if (r.isConfirmed) window.location.href=`/delete-allocation/${id}`; });
}

async function checkRoomForSwap() {
    const roomNo = document.getElementById('swapRoomNo').value;
    const date = document.getElementById('swapDate').value;
    const session = document.getElementById('swapSession').value;
    if (!roomNo || !date) { Swal.fire({ icon:'info', title:'Required', text:'Enter Room and Date.', background:'var(--card)', color:'var(--text)' }); return; }
    try {
        const res = await fetch('/get-swap-details', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({room_number:roomNo,date,session}) });
        const data = await res.json();
        if (data.success) {
            activeAllocationId = data.allocation.id;
            document.getElementById('currentAllocInfo').textContent = `Current: ${data.allocation.branch} | Year ${data.allocation.year}`;
            const sel = document.getElementById('availableRoomsSelect');
            sel.innerHTML = data.availableRooms.map(r => `<option value="${r.id}">Hall ${r.room_number} (${r.capacity} seats)</option>`).join('');
            document.getElementById('swapActionArea').style.display = 'block';
        } else { Swal.fire({ icon:'error', title:'Failed', text:data.message, background:'var(--card)', color:'var(--text)' }); }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'Server error.', background:'var(--card)', color:'var(--text)' }); }
}

async function confirmSmartSwap() {
    const new_room_id = document.getElementById('availableRoomsSelect').value;
    if (!activeAllocationId) return;
    try {
        const res = await fetch('/swap-room', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({allocation_id:activeAllocationId,new_room_id}) });
        const result = await res.json();
        if (result.success) {
            Swal.fire({ title:'Swapped!', icon:'success', timer:1800, showConfirmButton:false, background:'var(--card)', color:'var(--text)', willClose:()=>location.reload() });
        }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'Failed to swap.', background:'var(--card)', color:'var(--text)' }); }
}

async function searchStudent() {
    const roll_no = document.getElementById('findRoll').value;
    const date = document.getElementById('findDate').value;
    const session = document.getElementById('findSession').value;
    if (!roll_no || !date) { Swal.fire({ icon:'info', title:'Required', text:'Enter Roll Number and Date.', background:'var(--card)', color:'var(--text)' }); return; }
    try {
        const res = await fetch('/find-student-room', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({roll_no,date,session}) });
        const data = await res.json();
        if (data.success) {
            Swal.fire({ title:'Room Found!', html:`<span style="font-size:56px;font-weight:900;color:var(--accent);">${data.room}</span>`, icon:'success', confirmButtonColor:'var(--accent)', background:'var(--card)', color:'var(--text)' });
        } else {
            Swal.fire({ icon:'error', title:'Not Found', text:data.message, background:'var(--card)', color:'var(--text)' });
        }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'Request failed.', background:'var(--card)', color:'var(--text)' }); }
}
</script>
