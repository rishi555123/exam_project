<%- include('partials/header') %>

<div style="max-width:1200px;margin:0 auto;padding:32px 24px;font-style:italic;font-weight:900;">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:20px;">

        <!-- Forms -->
        <div style="display:flex;flex-direction:column;gap:16px;">
            <div class="t-card" style="padding:28px;border-top:4px solid var(--accent);">
                <p class="t-label" style="margin-bottom:18px;">Add Single Hall</p>
                <form id="singleRoomForm" action="/add-room-single" method="POST" onsubmit="handleSingleRoom(event)" style="display:flex;flex-direction:column;gap:10px;">
                    <input name="r_num" id="r_num" placeholder="Room Number (e.g. 101)" class="t-input" required>
                    <input name="cap" id="cap" type="number" placeholder="Seating Capacity" class="t-input" required>
                    <button type="submit" class="btn-primary" style="padding:14px;">Save Hall</button>
                </form>
            </div>

            <div class="t-card" style="padding:28px;border-top:4px solid var(--green);">
                <p class="t-label" style="margin-bottom:18px;">Bulk Import (CSV)</p>
                <form id="bulkRoomForm" action="/bulk-rooms" method="POST" onsubmit="handleBulkRooms(event)">
                    <textarea name="room_data" id="room_data" rows="6" class="t-input" style="resize:vertical;margin-bottom:10px;"
                              placeholder="Format: RoomNumber,Capacity&#10;e.g. 101,36&#10;102,40"></textarea>
                    <button type="submit" class="btn-secondary" style="width:100%;padding:14px;">Process Batch</button>
                </form>
            </div>
        </div>

        <!-- Table -->
        <div class="t-card" style="overflow:hidden;">
            <table class="t-table">
                <thead>
                    <tr>
                        <th style="text-align:left;">Hall</th>
                        <th style="text-align:center;">Capacity</th>
                        <th style="text-align:right;padding-right:24px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(rooms.length > 0) { %>
                        <% rooms.forEach(r => { %>
                            <tr>
                                <td style="font-weight:900;text-transform:uppercase;color:var(--text);font-size:13px;">
                                    Hall <%= r.room_number %>
                                </td>
                                <td style="text-align:center;">
                                    <span style="color:var(--green);font-weight:900;"><%= r.capacity %></span>
                                    <span style="color:var(--text3);font-size:9px;margin-left:4px;">seats</span>
                                </td>
                                <td style="text-align:right;padding-right:24px;">
                                    <button onclick="confirmRoomDelete('<%= r.id %>','<%= r.room_number %>')" class="btn-danger" style="padding:6px 12px;font-size:9px;">Remove</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="padding:60px;text-align:center;color:var(--text3);text-transform:uppercase;letter-spacing:0.3em;">
                                <i class="fas fa-door-open" style="font-size:32px;display:block;margin-bottom:12px;"></i>
                                No halls registered.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function handleSingleRoom(event) {
    event.preventDefault();
    const roomNum = document.getElementById('r_num').value;
    const capacity = document.getElementById('cap').value;
    Swal.fire({ title:'Register Hall?', text:`Add Hall ${roomNum} with ${capacity} seats?`, icon:'question', showCancelButton:true,
        confirmButtonColor:'var(--accent)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Save'
    }).then(r => { if (r.isConfirmed) { Swal.showLoading(); event.target.submit(); } });
}
function handleBulkRooms(event) {
    event.preventDefault();
    if (!document.getElementById('room_data').value.trim()) {
        Swal.fire({ icon:'info', title:'Empty', text:'Please enter room data.', background:'var(--card)', color:'var(--text)' }); return;
    }
    Swal.fire({ title:'Import Rooms?', text:'Multiple halls will be added.', icon:'info', showCancelButton:true,
        confirmButtonColor:'var(--green)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Import'
    }).then(r => { if (r.isConfirmed) { Swal.showLoading(); event.target.submit(); } });
}
function confirmRoomDelete(id, num) {
    Swal.fire({ title:'Remove Hall?', text:`Hall ${num} will be permanently removed.`, icon:'warning', showCancelButton:true,
        confirmButtonColor:'var(--red)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Remove'
    }).then(r => { if (r.isConfirmed) window.location.href=`/delete-room/${id}`; });
}
</script>
