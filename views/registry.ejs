<%- include('partials/header') %>

<div style="max-width:1400px;margin:0 auto;padding:32px 24px;font-style:italic;font-weight:900;">

    <!-- Search + Filter Bar -->
    <div class="t-card" style="padding:24px;margin-bottom:20px;">
        <form action="/manage-students" method="GET" style="margin-bottom:16px;position:relative;">
            <i class="fas fa-search" style="position:absolute;left:16px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:13px;"></i>
            <input name="search" value="<%= search %>" placeholder="Search by Roll Number or Name..."
                   class="t-input" style="padding-left:44px;">
        </form>
        <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
            <% [1,2,3,4].forEach(y => { %>
                <a href="/manage-students?year=<%= y %><%= br ? '&branch='+br : '' %>"
                   style="padding:8px 18px;border-radius:12px;font-size:10px;font-weight:900;font-style:italic;text-transform:uppercase;text-decoration:none;transition:all 0.2s;border:1px solid;
                   <%= yr == y ? 'background:var(--text);color:var(--bg);border-color:var(--text);' : 'background:var(--card2);color:var(--text2);border-color:var(--border2);' %>">
                    <%= y %><%= y==1?'st':y==2?'nd':y==3?'rd':'th' %> Year
                </a>
            <% }) %>
            <div style="width:1px;height:28px;background:var(--divider);margin:0 4px;"></div>
            <% branches.forEach(b => { %>
                <a href="/manage-students?branch=<%= b %><%= yr ? '&year='+yr : '' %>"
                   style="padding:8px 18px;border-radius:12px;font-size:10px;font-weight:900;font-style:italic;text-transform:uppercase;text-decoration:none;transition:all 0.2s;border:1px solid;
                   <%= br == b ? 'background:var(--accent);color:#fff;border-color:var(--accent);' : 'background:var(--card2);color:var(--text2);border-color:var(--border2);' %>">
                    <%= b %>
                </a>
            <% }) %>
            <a href="/manage-students" style="margin-left:auto;padding:8px 16px;border-radius:12px;font-size:9px;font-weight:900;font-style:italic;text-transform:uppercase;text-decoration:none;background:rgba(239,68,68,0.08);color:var(--red);border:1px solid rgba(239,68,68,0.25);transition:all 0.2s;"
               onmouseover="this.style.background='var(--red)';this.style.color='#fff'"
               onmouseout="this.style.background='rgba(239,68,68,0.08)';this.style.color='var(--red)'">Reset</a>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.5fr;gap:20px;">
        <!-- Forms Column -->
        <div style="display:flex;flex-direction:column;gap:16px;">
            <!-- Single Add -->
            <div class="t-card" style="padding:28px;border-top:4px solid var(--accent);">
                <p class="t-label" style="margin-bottom:18px;">Manual Registration</p>
                <form id="singleStudentForm" action="/add-student-single" method="POST" onsubmit="handleSingleStudent(event)" style="display:flex;flex-direction:column;gap:10px;">
                    <input name="roll" id="roll" placeholder="Registration Number" class="t-input" required>
                    <input name="name" id="name" placeholder="Full Name" class="t-input" required>
                    <select name="branch" id="branch" class="t-input">
                        <% branches.forEach(b => { %><option value="<%= b %>"><%= b %></option><% }) %>
                    </select>
                    <input name="year" id="year" type="number" placeholder="Academic Year (1-4)" class="t-input" required>
                    <button type="submit" class="btn-primary" style="padding:14px;">Register Student</button>
                </form>
            </div>

            <!-- Bulk Add -->
            <div class="t-card" style="padding:28px;border-top:4px solid var(--green);">
                <p class="t-label" style="margin-bottom:18px;">Batch Upload (CSV)</p>
                <form id="bulkStudentForm" action="/bulk-upload" method="POST" onsubmit="handleBulkStudents(event)">
                    <textarea name="csv_data" id="csv_data" rows="6" class="t-input" style="resize:vertical;margin-bottom:10px;"
                              placeholder="Format: RollNo,Name,Year,Branch&#10;e.g. 24B91A0555,Rishith,2,CSE"></textarea>
                    <button type="submit" class="btn-secondary" style="width:100%;padding:14px;">Process Batch</button>
                </form>
            </div>
        </div>

        <!-- Table Column -->
        <div class="t-card" style="overflow:hidden;">
            <table class="t-table">
                <thead>
                    <tr>
                        <th style="text-align:left;">Student</th>
                        <th style="text-align:left;">Dept</th>
                        <th style="text-align:right;padding-right:24px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(students.length > 0) { %>
                        <% students.forEach(s => { %>
                            <tr>
                                <td>
                                    <div style="font-weight:900;text-transform:uppercase;color:var(--text)"><%= s.roll_no %></div>
                                    <div style="font-size:9px;color:var(--text3);text-transform:uppercase;margin-top:2px;"><%= s.name %></div>
                                </td>
                                <td>
                                    <span style="color:var(--accent);font-weight:900;text-transform:uppercase;"><%= s.branch %></span>
                                    <span style="color:var(--border2);margin:0 4px;">·</span>
                                    <span style="color:var(--text2);font-size:10px;">Yr <%= s.year %></span>
                                </td>
                                <td style="text-align:right;padding-right:24px;">
                                    <button onclick="confirmStudentDelete('<%= s.id %>','<%= s.roll_no %>')" class="btn-danger" style="padding:6px 12px;font-size:9px;">Remove</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="padding:60px;text-align:center;color:var(--text3);text-transform:uppercase;letter-spacing:0.3em;">
                                <i class="fas fa-user-slash" style="font-size:32px;display:block;margin-bottom:12px;"></i>
                                No records found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function handleSingleStudent(event) {
    event.preventDefault();
    const roll = document.getElementById('roll').value;
    const name = document.getElementById('name').value;
    Swal.fire({ title:'Confirm Registration', text:`Register ${name} (${roll})?`, icon:'question', showCancelButton:true,
        confirmButtonColor:'var(--accent)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Register'
    }).then(r => { if (r.isConfirmed) { Swal.showLoading(); event.target.submit(); } });
}
function handleBulkStudents(event) {
    event.preventDefault();
    if (!document.getElementById('csv_data').value.trim()) {
        Swal.fire({ icon:'info', title:'Empty', text:'Please provide CSV data.', background:'var(--card)', color:'var(--text)' }); return;
    }
    Swal.fire({ title:'Process Batch?', text:'Multiple records will be added.', icon:'info', showCancelButton:true,
        confirmButtonColor:'var(--green)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Import'
    }).then(r => { if (r.isConfirmed) { Swal.showLoading(); event.target.submit(); } });
}
function confirmStudentDelete(id, roll) {
    Swal.fire({ title:'Remove Student?', text:`Permanently remove ${roll}?`, icon:'warning', showCancelButton:true,
        confirmButtonColor:'var(--red)', background:'var(--card)', color:'var(--text)', confirmButtonText:'Delete'
    }).then(r => { if (r.isConfirmed) window.location.href=`/delete-student/${id}`; });
}
</script>
