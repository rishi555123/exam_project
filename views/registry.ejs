<%- include('partials/header') %>

<div class="max-w-[1400px] mx-auto px-6 py-10 italic font-black">
    
    <div class="bg-white p-10 rounded-[3.5rem] shadow-2xl border border-slate-100 font-black italic mb-10">
        <form action="/manage-students" method="GET" class="relative mb-8">
            <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input name="search" value="<%= search %>" placeholder="Search by Roll Number or Full Name..." 
                   class="w-full pl-14 pr-6 py-5 rounded-2xl bg-slate-50 text-slate-900 border-2 border-slate-100 outline-none focus:border-indigo-400 transition-all font-black shadow-inner">
        </form>

        <div class="flex flex-wrap items-center gap-3">
            <% [1,2,3,4].forEach(y => { %>
                <a href="/manage-students?year=<%= y %><%= br ? '&branch='+br : '' %>" 
                   class="px-8 py-3 rounded-2xl text-[11px] font-black border-2 transition-all duration-300
                   <%= yr == y ? 'bg-slate-950 text-white border-slate-950 shadow-xl scale-105' : 'bg-white text-slate-400 border-slate-50 hover:border-slate-200 hover:text-slate-600' %>">
                   <%= y %><%= y==1?'ST':y==2?'ND':y==3?'RD':'TH' %> YEAR
                </a>
            <% }) %>

            <div class="w-px h-8 bg-slate-200 mx-3"></div>

            <% branches.forEach(b => { %>
                <a href="/manage-students?branch=<%= b %><%= yr ? '&year='+yr : '' %>" 
                   class="px-8 py-3 rounded-2xl text-[11px] font-black border-2 transition-all duration-300
                   <%= br == b ? 'bg-indigo-600 text-white border-indigo-600 shadow-xl scale-105' : 'bg-white text-slate-400 border-slate-50 hover:border-slate-200 hover:text-slate-600' %>">
                   <%= b %>
                </a>
            <% }) %>

            <a href="/manage-students" class="ml-auto px-6 py-3 rounded-2xl text-[10px] font-black bg-rose-50 text-rose-600 border border-rose-100 hover:bg-rose-600 hover:text-white transition-all uppercase tracking-widest">
                RESET FILTERS
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <div class="space-y-8">
            <div class="bg-white p-10 rounded-[3.5rem] shadow-2xl border-t-8 border-indigo-600 text-slate-900">
                <h3 class="mb-6 uppercase text-[10px] text-slate-400 tracking-widest font-black">Manual Student Registration</h3>
                <form id="singleStudentForm" action="/add-student-single" method="POST" onsubmit="handleSingleStudent(event)" class="flex flex-col gap-4">
                    <input name="roll" id="roll" placeholder="REGISTRATION NUMBER" class="p-5 border-2 border-slate-100 rounded-2xl bg-slate-50 text-slate-900 outline-none focus:border-indigo-400 transition-all font-black uppercase" required>
                    <input name="name" id="name" placeholder="FULL NAME" class="p-5 border-2 border-slate-100 rounded-2xl bg-slate-50 text-slate-900 outline-none focus:border-indigo-400 transition-all font-black uppercase" required>
                    
                    <select name="branch" id="branch" class="p-5 border-2 border-slate-100 rounded-2xl bg-slate-50 text-slate-900 outline-none focus:border-indigo-400 transition-all font-black uppercase">
                        <% branches.forEach(b => { %> 
                            <option value="<%= b %>"><%= b %></option> 
                        <% }) %>
                    </select>

                    <input name="year" id="year" type="number" placeholder="ACADEMIC YEAR (1-4)" class="p-5 border-2 border-slate-100 rounded-2xl bg-slate-50 text-slate-900 outline-none focus:border-indigo-400 transition-all font-black" required>
                    
                    <button type="submit" class="bg-indigo-600 text-white py-5 rounded-[2rem] uppercase shadow-[0_15px_30px_rgba(79,70,229,0.3)] hover:bg-indigo-700 hover:scale-[1.02] active:scale-95 transition-all font-black italic tracking-widest">
                        Register Student
                    </button>
                </form>
            </div>

            <div class="bg-white p-10 rounded-[3.5rem] shadow-2xl border-t-8 border-emerald-600 text-slate-900">
                <h3 class="mb-6 uppercase text-[10px] text-slate-400 tracking-widest font-black">Batch Student Upload (CSV)</h3>
                <form id="bulkStudentForm" action="/bulk-upload" method="POST" onsubmit="handleBulkStudents(event)">
                    <textarea name="csv_data" id="csv_data" rows="5" class="w-full p-6 border-2 border-slate-100 rounded-3xl bg-slate-50 text-slate-900 mb-6 outline-none focus:border-emerald-500 transition-all font-black" placeholder="Format: RollNo,Name,Year,Branch (e.g. 24241A0555,Rishith,2,CSE)"></textarea>
                    <button type="submit" class="w-full bg-slate-900 text-white py-5 rounded-[2rem] uppercase hover:bg-black transition-all font-black italic tracking-widest shadow-xl">
                        Process Registry Batch
                    </button>
                </form>
            </div>
        </div>

        <div class="bg-white rounded-[3.5rem] shadow-2xl border border-slate-100 overflow-hidden h-fit">
            <table class="w-full text-left text-[11px]">
                <thead class="bg-slate-950 text-indigo-300 uppercase italic">
                    <tr>
                        <th class="p-8 tracking-widest">Student Identity</th>
                        <th class="p-8 tracking-widest">Academic Dept</th>
                        <th class="p-8 text-right pr-12 tracking-widest">Control</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 text-slate-900">
                    <% if(students.length > 0) { %>
                        <% students.forEach(s => { %>
                            <tr class="hover:bg-indigo-50/50 transition-all group">
                                <td class="p-8">
                                    <span class="font-black text-slate-900 text-sm uppercase"><%= s.roll_no %></span><br>
                                    <span class="text-[10px] text-slate-400 uppercase tracking-tight font-bold"><%= s.name %></span>
                                </td>
                                <td class="p-8 uppercase text-indigo-600 font-black">
                                    <%= s.branch %> <span class="text-slate-200 mx-2">|</span> YEAR <%= s.year %>
                                </td>
                                <td class="p-8 pr-12 text-right">
                                    <button onclick="confirmStudentDelete('<%= s.id %>', '<%= s.roll_no %>')" class="text-rose-500 font-black uppercase hover:text-rose-700 transition-all italic border-b-2 border-transparent hover:border-rose-500 pb-1">Remove</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="p-24 text-center">
                                <i class="fas fa-user-slash text-5xl text-slate-100 mb-4 block"></i>
                                <p class="text-slate-300 uppercase font-black italic tracking-widest">No matching registry records.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
// --- FORMAL ALERT LOGIC ---
function handleSingleStudent(event) {
    event.preventDefault();
    const roll = document.getElementById('roll').value;
    const name = document.getElementById('name').value;
    Swal.fire({
        title: 'Confirm Registration',
        text: `Proceed with the registration for Student: ${name} (${roll})?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#4f46e5',
        confirmButtonText: 'Confirm Entry'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({
                title: 'Updating Registry',
                didOpen: () => {
                    Swal.showLoading();
                    event.target.submit();
                }
            });
        }
    });
}

function handleBulkStudents(event) {
    event.preventDefault();
    const data = document.getElementById('csv_data').value.trim();
    if (!data) {
        Swal.fire({ icon: 'info', title: 'Input Required', text: 'Please provide student data in CSV format.', confirmButtonColor: '#1e293b' });
        return;
    }
    Swal.fire({
        title: 'Process Batch Import?',
        text: 'Multiple records will be added. Ensure data integrity.',
        icon: 'info',
        showCancelButton: true,
        confirmButtonColor: '#059669',
        confirmButtonText: 'Start Processing'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.showLoading();
            event.target.submit();
        }
    });
}

function confirmStudentDelete(id, roll) {
    Swal.fire({
        title: 'Remove Student?',
        text: `Permanent removal of Student ID: ${roll}.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#1e293b',
        confirmButtonText: 'Delete Record',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/delete-student/${id}`;
        }
    });
}
</script>