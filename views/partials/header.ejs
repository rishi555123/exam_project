<!DOCTYPE html>
<html lang="en" id="htmlRoot">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GRIET Smart EMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* ═══════════════════════════════════════
           DARK MODE — default
        ═══════════════════════════════════════ */
        :root {
            --bg:           #07080f;
            --bg2:          #0d1117;
            --card:         #111827;
            --card2:        #1a2235;
            --input-bg:     #0d1117;
            --border:       #1e2d40;
            --border2:      #253347;
            --text:         #f0f4ff;
            --text2:        #8b9ab5;
            --text3:        #4a5978;
            --accent:       #6366f1;
            --accent-glow:  rgba(99,102,241,0.25);
            --green:        #10b981;
            --amber:        #f59e0b;
            --red:          #ef4444;
            --nav:          rgba(7,8,15,0.92);
            --badge-bg:     #1e2d40;
            --table-head:   #0d1117;
            --table-row:    #111827;
            --table-hover:  #1a2235;
            --divider:      #1e2d40;
            --tag-bg:       #1e2d40;
        }
        /* ═══════════════════════════════════════
           LIGHT MODE
        ═══════════════════════════════════════ */
        html.light {
            --bg:           #f0f4ff;
            --bg2:          #e8edf8;
            --card:         #ffffff;
            --card2:        #f5f8ff;
            --input-bg:     #f0f4ff;
            --border:       #dce3f0;
            --border2:      #c8d3e8;
            --text:         #0f172a;
            --text2:        #475569;
            --text3:        #94a3b8;
            --accent:       #4f46e5;
            --accent-glow:  rgba(79,70,229,0.12);
            --green:        #059669;
            --amber:        #d97706;
            --red:          #dc2626;
            --nav:          rgba(240,244,255,0.95);
            --badge-bg:     #e8edf8;
            --table-head:   #1e293b;
            --table-row:    #ffffff;
            --table-hover:  #eef2ff;
            --divider:      #dce3f0;
            --tag-bg:       #e8edf8;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            transition: background 0.3s, color 0.3s;
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .ems-nav {
            background: var(--nav);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(24px);
            position: sticky; top: 0; z-index: 200;
            padding: 0 24px;
            height: 60px;
            display: flex; align-items: center;
        }
        .nav-inner {
            max-width: 1400px; margin: 0 auto; width: 100%;
            display: flex; align-items: center; justify-content: space-between;
        }
        .nav-brand {
            font-size: 14px; font-weight: 900; font-style: italic;
            letter-spacing: 0.15em; color: var(--text);
            text-decoration: none; text-transform: uppercase;
        }
        .nav-brand span { color: var(--accent); }
        .nav-links { display: flex; gap: 2px; }
        .nav-link {
            color: var(--text2); font-size: 9px; font-weight: 900;
            text-transform: uppercase; letter-spacing: 0.18em;
            padding: 7px 14px; border-radius: 10px;
            transition: all 0.2s; text-decoration: none; font-style: italic;
        }
        .nav-link:hover { background: var(--accent-glow); color: var(--accent); }
        .nav-link.active { background: var(--accent-glow); color: var(--accent); }
        .nav-right { display: flex; align-items: center; gap: 10px; }

        /* Theme toggle */
        .theme-btn {
            width: 34px; height: 34px; border-radius: 10px;
            border: 1px solid var(--border2); background: var(--card);
            color: var(--text2); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; transition: all 0.2s;
        }
        .theme-btn:hover { color: var(--accent); border-color: var(--accent); }

        /* Logout */
        .logout-btn {
            font-size: 9px; font-weight: 900; font-style: italic;
            text-transform: uppercase; letter-spacing: 0.15em;
            padding: 7px 14px; border-radius: 10px;
            border: 1px solid rgba(239,68,68,0.25);
            color: #f87171; background: rgba(239,68,68,0.07);
            text-decoration: none; transition: all 0.2s;
        }
        .logout-btn:hover { background: rgba(239,68,68,0.18); border-color: var(--red); color: #fff; }

        /* ── Reusable themed classes ── */
        .t-card  { background: var(--card);  border: 1px solid var(--border); border-radius: 24px; }
        .t-card2 { background: var(--card2); border: 1px solid var(--border); border-radius: 20px; }
        .t-input {
            background: var(--input-bg); border: 1px solid var(--border2);
            color: var(--text); border-radius: 12px;
            padding: 12px 16px; font-size: 12px; font-weight: 700;
            width: 100%; outline: none; transition: border-color 0.2s;
            font-style: italic; font-family: inherit;
        }
        .t-input:focus { border-color: var(--accent); }
        .t-input::placeholder { color: var(--text3); }
        .t-label { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text2); }
        .t-text  { color: var(--text); }
        .t-muted { color: var(--text2); }
        .t-sub   { color: var(--text3); }
        .t-divider { border-color: var(--divider); }
        .t-badge { background: var(--badge-bg); color: var(--text2); border: 1px solid var(--border); border-radius: 8px; padding: 3px 10px; font-size: 9px; font-weight: 900; }
        .t-tag   { background: var(--tag-bg); color: var(--text2); border-radius: 8px; }

        /* Btn styles */
        .btn-primary {
            background: var(--accent); color: #fff; border: none; border-radius: 14px;
            padding: 12px 20px; font-size: 10px; font-weight: 900; font-style: italic;
            text-transform: uppercase; letter-spacing: 0.15em; cursor: pointer;
            transition: all 0.2s; box-shadow: 0 4px 20px var(--accent-glow);
        }
        .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
        .btn-secondary {
            background: var(--card2); color: var(--text); border: 1px solid var(--border2);
            border-radius: 14px; padding: 12px 20px; font-size: 10px;
            font-weight: 900; font-style: italic; text-transform: uppercase;
            letter-spacing: 0.15em; cursor: pointer; transition: all 0.2s;
        }
        .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
        .btn-danger {
            background: rgba(239,68,68,0.1); color: var(--red); border: 1px solid rgba(239,68,68,0.25);
            border-radius: 12px; padding: 8px 16px; font-size: 9px;
            font-weight: 900; font-style: italic; text-transform: uppercase; cursor: pointer; transition: all 0.2s;
        }
        .btn-danger:hover { background: var(--red); color: #fff; }

        /* Table */
        .t-table { width: 100%; border-collapse: collapse; font-size: 11px; }
        .t-table thead tr { background: var(--table-head); }
        .t-table thead th { padding: 16px 20px; color: #94a3b8; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.18em; font-style: italic; }
        .t-table tbody tr { background: var(--table-row); border-bottom: 1px solid var(--divider); transition: background 0.15s; }
        .t-table tbody tr:hover { background: var(--table-hover); }
        .t-table td { padding: 16px 20px; color: var(--text); }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 6px; }
    </style>
</head>
<body>
<nav class="ems-nav">
    <div class="nav-inner">
        <a href="/" class="nav-brand">GRIET <span>EMS</span></a>
        <div class="nav-links" id="navLinks">
            <a href="/"                class="nav-link">Dashboard</a>
            <a href="/manage-students" class="nav-link">Students</a>
            <a href="/manage-rooms"    class="nav-link">Rooms</a>
            <a href="/history"         class="nav-link">History</a>
        </div>
        <div class="nav-right">
            <button class="theme-btn" id="themeToggle" title="Toggle theme">
                <i class="fas fa-moon" id="themeIcon"></i>
            </button>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>
</nav>
<script>
    const html = document.getElementById('htmlRoot');
    const saved = localStorage.getItem('ems-theme') || 'dark';
    applyTheme(saved);
    document.getElementById('themeToggle').addEventListener('click', () => {
        const next = html.classList.contains('light') ? 'dark' : 'light';
        applyTheme(next);
        localStorage.setItem('ems-theme', next);
    });
    function applyTheme(mode) {
        html.classList.toggle('light', mode === 'light');
        document.getElementById('themeIcon').className = mode === 'light' ? 'fas fa-sun' : 'fas fa-moon';
    }
    // active nav
    const p = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(l => {
        const h = l.getAttribute('href');
        if (h === '/' ? p === '/' : p.startsWith(h)) l.classList.add('active');
    });
</script>
