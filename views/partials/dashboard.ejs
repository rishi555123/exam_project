<%- include('partials/header') %>
<div class="max-w-[1200px] mx-auto px-6 py-12 italic font-black">
    <form action="/generate" method="POST">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border mb-10 flex gap-6 italic">
            <div class="flex-1">
                <h3 class="text-[10px] uppercase text-slate-400 mb-2">Exam Date</h3>
                <input type="date" name="exam_date" value="<%= selDate %>" class="w-full p-4 border rounded-2xl bg-slate-50 font-black outline-none">
            </div>
            </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
            <% [1,2,3,4].forEach(y => { %>
                <div class="relative">
                    <input type="radio" name="selected_year" value="<%= y %>" id="yr_<%= y %>" class="hidden">
                    <label for="yr_<%= y %>" class="block p-8 bg-white border-2 border-slate-100 rounded-[2.5rem] cursor-pointer shadow-sm text-center">
                        <h4 class="text-xl uppercase"><%= y %>st Year</h4>
                        <p class="text-[10px] text-slate-400"><%= stats[y] ? stats[y].total : 0 %> Students</p>
                    </label>
                </div>
            <% }) %>
        </div>

        <div class="bg-white p-10 rounded-[3rem] shadow-2xl border">
            <button type="submit" class="w-full bg-slate-950 text-white py-5 rounded-[2rem] font-black uppercase tracking-widest">Generate Allocation</button>
        </div>
    </form>
</div>